# Supabase — get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Replicate — get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Replicate webhook signing secret
# Run: curl -H "Authorization: Bearer $REPLICATE_API_TOKEN" https://api.replicate.com/v1/webhooks/default/secret
REPLICATE_WEBHOOK_SIGNING_SECRET=

# Full app URL including scheme — used for Replicate webhook callback
# Local: http://localhost:3000
# With ngrok: https://your-id.ngrok-free.app
NEXT_PUBLIC_APP_URL=
